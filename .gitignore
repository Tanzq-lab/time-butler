node_modules/
.pnp.*
.yarn/*
!.yarn/patches/
!.yarn/plugins/
!.yarn/releases/
!.yarn/sdks/
!.yarn/versions/

# Build output and caches
dist/
build/
out/
.vite/
*.tsbuildinfo

# Test and coverage output
coverage/
.nyc_output/
playwright-report/
test-results/
blob-report/

