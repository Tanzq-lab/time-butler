lerna-debug.log*

# Environment and local secrets
.env
.env.*
!.env.example
!.env.sample

# Personal runtime data lives in the sibling private repo: ../time-butler-data
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal
*.sqlite-shm
*.sqlite-wal
data/*
!data/
!data/.gitkeep
backups/

