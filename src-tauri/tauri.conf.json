{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Time-butler",
  "version": "1.0.0",
  "identifier": "com.timebutler.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Time-butler",
        "width": 1280,
        "height": 720,
        "minWidth": 320,
        "minHeight": 700,
        "decorations": true,
        "transparent": false,
        "resizable": true,
        "center": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost data:; font-src 'self'; connect-src 'self' ipc: http://ipc.localhost https://github.com"
    }
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "active": true,
    "targets": "all",
    "resources": {
      "../src/assets/sounds/simple-happy-beep.ogg": "sounds/simple-happy-beep.ogg"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Tanzq-lab/time-butler/releases/latest/download/latest-{{target}}-{{arch}}.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI0MEJGMEY2NTBBNTFGRApSV1Q5VVFwbEQ3OUFBZ1kvdGltNEVxU3ZWRDlmRm5WejJWeC9oeENwdkpBczgxa1pDTTE1ZVN1bwo=",
      "v1Compatible": false
    }
  }
}
